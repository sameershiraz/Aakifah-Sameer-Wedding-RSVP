.wa-btn-role {
  font-family: 'Cinzel', serif; font-size: 9px;
  letter-spacing: 0.25em; color: var(--gold);
  text-transform: uppercase; margin-bottom: 3px;
}
.wa-btn-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px; color: #111111; font-weight: 400;
}
.wa-btn-num {
  font-family: 'Lato', sans-serif;
  font-size: 13px; color: #2a5a62; font-weight: 400; margin-top: 2px;
}
.wa-icon-circle {
  background: #34656D; border-radius: 50%;
  width: 44px; height: 44px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
}

.rsvp-error {
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px; color: #c0392b;
  text-align: center; margin-top: 12px;
  display: none;
}
.rsvp-success {
  text-align: center; padding: 24px;
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px; color: #34656D;
  display: none;
}

/* ── SUBMIT BUTTON ── */
.submit-btn {
  width: 100%;
  padding: 18px;
  background: linear-gradient(135deg, #34656D, #4a8a94);
  color: #fff;
  font-family: 'Cinzel', serif;
  font-size: 15px;
  letter-spacing: 0.22em;
  border: none;
  border-radius: 6px;
