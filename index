.submit-btn:hover { opacity: 0.88; transform: translateY(-2px); }
.submit-btn:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }

/* ── RSVP ── */
#rsvp {
  text-align: center;
  padding: clamp(60px, 8vw, 100px) 20px;
  background: #fdf6ec;
}



