/* ── FOOTER ── */
footer {
  background: #0f2226;
  padding: 48px 20px;
  text-align: center;
}
.footer-names {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(22px, 4vw, 36px);
  color: var(--gold-light);
  margin-bottom: 12px;
}
.footer-date {
  font-family: 'Cinzel', serif;
  font-size: 12px; letter-spacing: 0.2em;
  color: rgba(255,255,255,0.7);
}

/* ── GOLD BORDER FRAME ── */
.gold-frame {
  border: 1px solid rgba(201,168,76,0.25);
  padding: 32px;
  position: relative;
}
.gold-frame::before, .gold-frame::after {
  content: '✦';
  position: absolute;
  color: var(--gold);
  font-size: 14px;
  opacity: 0.6;
}
.gold-frame::before { top: 10px; left: 10px; }
.gold-frame::after  { bottom: 10px; right: 10px; }


/* ── PHOTO GALLERY ── */
#photos { background: #fdf6ec; }
.photo-frame {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 1s cubic-bezier(0.22,1,0.36,1), transform 1s cubic-bezier(0.22,1,0.36,1);
}
.photo-frame.visible { opacity: 1; transform: none; }
.photo-frame-right { transition-delay: 0.22s; }
.photo-img-wrap {
  position: relative;
  border-radius: 4px;
  overflow: hidden;
  box-shadow: 0 20px 60px rgba(0,0,0,0.16);
}
.photo-img-wrap::after {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(13,26,16,0.4) 0%, transparent 55%);
  pointer-events: none;
}
.photo-img-wrap img {
  width: 100%; display: block; object-fit: cover;
  transition: transform 0.6s ease;
}
.photo-img-wrap:hover img { transform: scale(1.03); }
.photo-caption {
  text-align: center; margin-top: 14px;
  font-family: 'Cinzel', serif;
  font-size: 12px; letter-spacing: 0.2em;
  color: var(--gold); text-transform: uppercase;
}
.photo-middle {
  flex: 1; min-width: 180px; max-width: 280px;
  text-align: center;
  opacity: 0; transform: scale(0.92);
  transition: opacity 0.9s ease 0.12s, transform 0.9s ease 0.12s;
}
